{
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@3.0.0"]
    },
    "codegraph": {
      "type": "stdio",
      "command": "codegraph",
      "args": ["serve", "--mcp"]
    },
    "mem-search": {
      "type": "stdio",
      "command": "sh",
      "args": ["-c", "bun run ~/.pilot/scripts/mcp-server.cjs"]
    },
    "web-search": {
      "command": "npx",
      "args": ["-y", "open-websearch@2.1.11"],
      "env": {
        "MODE": "stdio",
        "DEFAULT_SEARCH_ENGINE": "duckduckgo",
        "ALLOWED_SEARCH_ENGINES": "duckduckgo,bing,exa"
      }
    },
    "grep-mcp": {
      "type": "http",
      "url": "https://mcp.grep.app"
    },
    "web-fetch": {
      "command": "npx",
      "args": ["-y", "fetcher-mcp@0.3.9"]
    },
    "semble": {
      "command": "uvx",
      "args": ["--from", "semble[mcp]", "semble"]
    }
  }
}
