{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project python \"$HOME/.pilot/hooks/license_check.py\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "uv run --no-project python \"$HOME/.pilot/hooks/codegraph_init.py\"",
            "timeout": 120
          },
          {
            "type": "command",
            "command": "uv run --no-project python \"$HOME/.pilot/hooks/codex_skill_sync.py\"",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "bun \"$HOME/.pilot/scripts/worker-service.cjs\" hook codex context",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "clear",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project python \"$HOME/.pilot/hooks/session_clear.py\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project python \"$HOME/.pilot/hooks/post_compact_restore.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun \"$HOME/.pilot/scripts/worker-service.cjs\" hook codex session-init",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project python \"$HOME/.pilot/hooks/tool_token_saver.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project python \"$HOME/.pilot/hooks/file_checker.py\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "apply_patch|Edit|Write|Bash|Read",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project python \"$HOME/.pilot/hooks/context_monitor.py\"",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bun \"$HOME/.pilot/scripts/worker-service.cjs\" hook codex observation",
            "timeout": 3
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project python \"$HOME/.pilot/hooks/spec_stop_guard.py\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bun \"$HOME/.pilot/scripts/worker-service.cjs\" hook codex summarize",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "uv run --no-project python \"$HOME/.pilot/hooks/session_end.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project python \"$HOME/.pilot/hooks/pre_compact.py\"",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
