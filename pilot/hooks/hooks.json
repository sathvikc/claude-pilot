{
  "description": "Pilot Shell hooks - memory system and quality checks",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project python \"$HOME/.pilot/hooks/license_check.py\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "uv run --no-project python \"$HOME/.pilot/hooks/codegraph_init.py\"",
            "async": true,
            "timeout": 120
          },
          {
            "type": "command",
            "command": "uv run --no-project python \"$HOME/.pilot/hooks/codex_skill_sync.py\"",
            "async": true,
            "timeout": 30
          },
          {
            "type": "command",
            "command": "uv run --no-project python \"$HOME/.pilot/hooks/cc_skill_sync.py\"",
            "async": true,
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "bun \"$HOME/.pilot/scripts/worker-service.cjs\" hook claude-code context",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "bun \"$HOME/.pilot/scripts/worker-service.cjs\" hook claude-code user-message",
            "async": true,
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "clear",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project python \"$HOME/.pilot/hooks/session_clear.py\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project python \"$HOME/.pilot/hooks/post_compact_restore.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project python \"$HOME/.pilot/hooks/spec_mode_guard.py\""
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project python \"$HOME/.pilot/hooks/spec_handoff_resume.py\""
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun \"$HOME/.pilot/scripts/worker-service.cjs\" hook claude-code session-init",
            "async": true,
            "timeout": 15
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|WebSearch|WebFetch|Grep|Glob|Agent|EnterPlanMode|ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project python \"$HOME/.pilot/hooks/tool_redirect.py\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project python \"$HOME/.pilot/hooks/tool_token_saver.py\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project python \"$HOME/.pilot/hooks/file_checker.py\""
          }
        ]
      },
      {
        "matcher": "Read|Write|Edit|MultiEdit|Bash|Task|Skill|Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project python \"$HOME/.pilot/hooks/context_monitor.py\""
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bun \"$HOME/.pilot/scripts/worker-service.cjs\" hook claude-code observation",
            "async": true,
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project python \"$HOME/.pilot/hooks/spec_stop_guard.py\""
          },
          {
            "type": "command",
            "command": "bun \"$HOME/.pilot/scripts/worker-service.cjs\" hook claude-code summarize",
            "async": true,
            "timeout": 15
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project python \"$HOME/.pilot/hooks/session_end.py\"",
            "timeout": 15
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project python \"$HOME/.pilot/hooks/pre_compact.py\"",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
