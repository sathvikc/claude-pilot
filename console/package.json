{
  "name": "pilot-console",
  "version": "9.11.0",
  "description": "Memory system for Pilot Shell - persistent context and observations",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  },
  "scripts": {
    "dev": "npm run build",
    "dev:viewer": "vite",
    "build": "node scripts/build-hooks.js",
    "build:viewer": "vite build",
    "typecheck": "tsc --noEmit",
    "knip": "knip-bun",
    "test": "bun test",
    "test:sqlite": "bun test tests/sqlite/",
    "test:context": "bun test tests/context/",
    "test:worker": "bun test tests/worker/"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.12",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dompurify": "^3.3.3",
    "express": "^4.18.2",
    "yaml": "^2.8.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@git-diff-view/file": "^0.1.1",
    "@git-diff-view/react": "^0.1.1",
    "@happy-dom/global-registrator": "^20.9.0",
    "@iconify/react": "^6.0.2",
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.8",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.1.2",
    "daisyui": "^5.5.14",
    "esbuild": "^0.27.2",
    "happy-dom": "^20.8.9",
    "knip": "^6.15.0",
    "motion": "^12.38.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-is": "^18.3.1",
    "react-markdown": "^9.0.1",
    "recharts": "^3.7.0",
    "remark-gfm": "^4.0.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.3.0",
    "vite": "6.4.2"
